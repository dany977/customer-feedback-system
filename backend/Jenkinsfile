pipeline {
    agent any
    
    tools {
        nodejs 'NodeJS-20'  // Configure this in Jenkins first
        python 'Python-3.12'  // Configure this in Jenkins first
    }
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/dany977/customer-feedback-system.git'
            }
        }
        
        stage('Backend Setup') {
            steps {
                dir('backend') {
                    sh '''
                        python -m venv venv
                        ./venv/Scripts/activate  # Windows
                        # source venv/bin/activate  # Linux/Mac
                        pip install -r requirements.txt
                    '''
                }
            }
        }
        
        stage('Backend Migrations') {
            steps {
                dir('backend') {
                    sh '''
                        ./venv/Scripts/activate
                        python manage.py migrate
                    '''
                }
            }
        }
        
        stage('Frontend Setup') {
            steps {
                dir('frontend') {
                    sh '''
                        npm install
                    '''
                }
            }
        }
        
        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh '''
                        npm run build
                    '''
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                dir('backend') {
                    sh '''
                        ./venv/Scripts/activate
                        python manage.py test
                    '''
                }
            }
        }
        
        stage('Build Docker Images') {
            steps {
                sh '''
                    docker build -t feedback-backend ./backend
                    docker build -t feedback-frontend ./frontend
                '''
            }
        }
        
        stage('Deploy') {
            steps {
                sh '''
                    docker-compose up -d
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            echo 'Pipeline finished.'
        }
    }
}